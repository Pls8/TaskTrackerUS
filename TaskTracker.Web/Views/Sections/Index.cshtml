@model List<TaskTracker.Application.DTOs.TaskDto>
@{
    ViewData["Title"] = "Task Sections";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Task Sections</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Section</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Title / Description</th>
                    <th>Weight (%)</th>
                    <th>Section Progress (%)</th>
                    <th>Priority</th>
                    <th>Owner</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var secItem in Model)
                {
                    <tr>
                        <td><strong>@secItem.Title</strong> <br/> <small class="text-muted">@secItem.Description</small></td>
                        <td>@(secItem.TaskWeightPercentage?.ToString("F0"))%</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="progress flex-grow-1 me-2" style="height: 10px;">
                                    <div class="progress-bar" role="progressbar" style="width: @(secItem.SectionProgressPercentage ?? 0)%;" aria-valuenow="@(secItem.SectionProgressPercentage ?? 0)" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                                <span>@(secItem.SectionProgressPercentage?.ToString("F0"))%</span>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary">@secItem.Priority</span></td>
                        <td>@secItem.Owner</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@secItem.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form asp-action="Delete" asp-route-id="@secItem.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this section? This will also delete all child tasks!');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
