@model TaskTracker.Web.ViewModels.CreateTaskViewModel
@{
    ViewData["Title"] = "Create Section";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Create New Section</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Section Title</label>
                            <input asp-for="Title" class="form-control" placeholder="e.g. Infrastructure Setup" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TaskWeightPercentage" class="form-label">Section Weight (%)</label>
                                <input asp-for="TaskWeightPercentage" type="number" step="1" class="form-control" />
                                <div class="form-text">Percentage of the total project (e.g. 30, 40)</div>
                                <span asp-validation-for="TaskWeightPercentage" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Priority" class="form-label">Priority</label>
                                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<TaskTracker.Domain.Enums.PriorityLevel>()"></select>
                                <span asp-validation-for="Priority" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                             <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Owner" class="form-label">Owner</label>
                            <input asp-for="Owner" class="form-control" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Create Section</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
