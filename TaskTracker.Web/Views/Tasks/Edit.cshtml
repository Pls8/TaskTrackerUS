@model UpdateTaskViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Edit Task</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="ParentTaskId" class="form-label">Section (Required)</label>
                            <select asp-for="ParentTaskId" class="form-select" asp-items="ViewBag.ParentTasks">
                                <option value="">-- Select Section --</option>
                            </select>
                            <span asp-validation-for="ParentTaskId" class="text-danger"></span>
                            <div class="form-text">Moving this task to another section will trigger weight redistribution.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description (Required)</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">Title (Optional)</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Owner" class="form-label">Owner</label>
                                <select asp-for="Owner" class="form-select">
                                    <option value="">-- Select Owner --</option>
                                    <option value="ROP">ROP</option>
                                    <option value="United Solution">United Solution</option>
                                    <option value="ROP & United Solution">ROP & United Solution</option>
                                </select>
                                <span asp-validation-for="Owner" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Resource" class="form-label">Resource</label>
                                <input asp-for="Resource" class="form-control" />
                                <span asp-validation-for="Resource" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="TaskWeightPercentage" class="form-label">Task Weight (%)</label>
                                <input asp-for="TaskWeightPercentage" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="TaskWeightPercentage" class="text-danger"></span>
                                <div class="form-text">Manually changing this overrides auto-distribution.</div>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="TaskCompletionPercentage" class="form-label">Completion (%)</label>
                                <input asp-for="TaskCompletionPercentage" type="number" step="0.01" class="form-control" />
                                <span asp-validation-for="TaskCompletionPercentage" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                             <div class="col-md-6 mb-3">
                                <label asp-for="Priority" class="form-label">Priority</label>
                                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<TaskTracker.Domain.Enums.PriorityLevel>()"></select>
                                <span asp-validation-for="Priority" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Remark" class="form-label">Remark</label>
                            <textarea asp-for="Remark" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
