@model CreateTaskViewModel
@{
    ViewData["Title"] = "Create Task";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3>Create New Task</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        <div class="mb-3">
                            <label asp-for="ParentTaskId" class="form-label">Section (Required)</label>
                            <select asp-for="ParentTaskId" class="form-select" asp-items="ViewBag.ParentTasks">
                                <option value="">-- Select Section --</option>
                            </select>
                            <span asp-validation-for="ParentTaskId" class="text-danger"></span>
                            <div class="form-text">Task weight will be automatically distributed based on the selected section.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label">Description (Required)</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                        
                        <div class="row">
                             <div class="col-md-6 mb-3">
                                <label asp-for="TaskWeightPercentage" class="form-label">Task Weight (%)</label>
                                <input asp-for="TaskWeightPercentage" type="number" step="0.01" class="form-control" placeholder="Auto-calculated" />
                                <div class="form-text">Leave blank to auto-calculate.</div>
                                <span asp-validation-for="TaskWeightPercentage" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Priority" class="form-label">Priority</label>
                                <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<TaskTracker.Domain.Enums.PriorityLevel>()"></select>
                                <span asp-validation-for="Priority" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Remark" class="form-label">Remark</label>
                            <textarea asp-for="Remark" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Create Task</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
